{
  "name": "multi-agent-group-chat",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\"",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace backend run build && npm --workspace frontend run build",
    "start": "npm --workspace backend run start",
    "smoke": "powershell -NoProfile -File .\\scripts\\smoke-with-server.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
